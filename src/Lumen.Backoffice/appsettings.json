{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jobs": {
    "Enabled": true,
    "AbandonedCart": {
      "InactiveHours": 24,
      "CronExpression": "0 0 * * * ?"
    },
    "CartCleanup": {
      "MaxAgeDays": 30,
      "CronExpression": "0 30 2 * * ?"
    },
    "OrderStatus": {
      "PendingHours": 48,
      "CronExpression": "0 0 6 * * ?"
    },
    "InventorySync": {
      "CronExpression": "0 0 3 * * ?"
    }
  },
  "Payments": {
    "Provider": "dummy",
    "Currency": "SEK",
    "Dummy": {
      "SimulateFailure": false,
      "FailureMessage": "Payment declined (simulated)."
    }
  }
}
