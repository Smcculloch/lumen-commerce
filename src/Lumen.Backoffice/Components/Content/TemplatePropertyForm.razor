@using Lumen.Domain.Templates

@if (Template is null)
{
    <div class="alert alert-warning mb-3">
        Template fields could not be loaded. Go back and choose a template again, or refresh the page.
    </div>
}
else if (Template.Properties.Count == 0)
{
    <p class="text-muted">This template has no editable properties.</p>
}
else
{
    <div class="card mb-3">
        <div class="card-header">
            Template: <strong>@Template.DisplayName</strong>
            <span class="text-muted small ms-2">(@Template.Key)</span>
        </div>
        <div class="card-body">
            @foreach (var property in Template.Properties.OrderBy(p => p.SortOrder))
            {
                @if (ShouldSkipProperty(property.Name))
                {
                    continue;
                }

                <TemplatePropertyField Definition="property"
                                       Value="@GetValue(property.Name)"
                                       ValueChanged="value => SetValue(property.Name, value)"
                                       Errors="@GetErrors(property.Name)" />
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public ResolvedTemplateDefinition? Template { get; set; }

    [Parameter]
    public Dictionary<string, string> PropertyValues { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    public EventCallback<Dictionary<string, string>> PropertyValuesChanged { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, string[]>? ValidationErrors { get; set; }

    [Parameter]
    public bool SkipNameAndSlugFields { get; set; } = true;

    private string GetValue(string name) =>
        PropertyValues.TryGetValue(name, out var value) ? value : string.Empty;

    private async Task SetValue(string name, string value)
    {
        PropertyValues[name] = value;
        if (PropertyValuesChanged.HasDelegate)
        {
            await PropertyValuesChanged.InvokeAsync(PropertyValues);
        }
    }

    private string[]? GetErrors(string name) =>
        ValidationErrors is not null && ValidationErrors.TryGetValue(name, out var errors) ? errors : null;

    private bool ShouldSkipProperty(string name) =>
        SkipNameAndSlugFields &&
        (string.Equals(name, "title", StringComparison.OrdinalIgnoreCase) ||
         string.Equals(name, "slug", StringComparison.OrdinalIgnoreCase));
}