@page "/settings"

<PageTitle>Settings</PageTitle>

<h1 class="mb-2">Settings</h1>
<p class="text-muted mb-4">Configure templates and system options for Lumen Commerce.</p>

<div class="row g-3">
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 settings-card">
            <div class="card-body">
                <h2 class="h5 card-title">
                    <span class="oi oi-folder me-2" aria-hidden="true"></span>
                    Content Templates
                </h2>
                <p class="card-text text-muted">
                    Manage CMS page templates — view code-defined templates, add extension properties, and create dynamic templates.
                </p>
                <a class="btn btn-primary" href="settings/templates/content">Manage content templates</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 settings-card">
            <div class="card-body">
                <h2 class="h5 card-title">
                    <span class="oi oi-tag me-2" aria-hidden="true"></span>
                    Product Templates
                </h2>
                <p class="card-text text-muted">
                    Manage PIM product templates — extend standard product fields or create fully dynamic product templates.
                </p>
                <a class="btn btn-primary" href="settings/templates/product">Manage product templates</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 settings-card border-dashed opacity-75">
            <div class="card-body">
                <h2 class="h5 card-title text-muted">
                    <span class="oi oi-cog me-2" aria-hidden="true"></span>
                    General settings
                </h2>
                <p class="card-text text-muted">
                    Site-wide configuration, email templates, and integrations — planned for a future phase.
                </p>
                <button class="btn btn-outline-secondary" disabled>Coming soon</button>
            </div>
        </div>
    </div>
</div>