@page "/settings/templates/content/{Key}"
@using Lumen.Backoffice.Components.Settings

<PageTitle>Content Template</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="settings">Settings</a></li>
        <li class="breadcrumb-item"><a href="settings/templates/content">Content Templates</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Key</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Manage content template</h1>
    <a class="btn btn-outline-secondary" href="settings/templates/content">Back to list</a>
</div>

<TemplateDetailPanel TemplateKey="@Key" AreaLabel="content" ListUrl="settings/templates/content" />

@code {
    [Parameter]
    public string Key { get; set; } = string.Empty;
}