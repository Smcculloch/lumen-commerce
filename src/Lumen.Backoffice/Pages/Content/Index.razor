@page "/content"
@using Lumen.Application.Content
@using Lumen.Application.Content.Dtos
@using Lumen.Backoffice.Components.Content
@using Lumen.Domain.Enums
@inject IContentService ContentService

<PageTitle>Content</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="mb-0">Content</h1>
        <p class="text-muted mb-0">Browse the site hierarchy in the tree and preview page content on the right.</p>
    </div>
    <a class="btn btn-primary" href="content/new">Create Root Content</a>
</div>

<AlertBanner Message="@_bannerMessage" IsError="@_bannerIsError" OnDismiss="ClearBanner" />

<div class="row g-2 mb-3 align-items-center">
    <div class="col-md-5">
        <input class="form-control" placeholder="Search by name, slug, path, or template..."
               @bind="_search" @bind:event="oninput" @bind:after="OnSearchChanged" />
    </div>
    <div class="col-md-7">
        <div class="d-flex flex-wrap gap-2 justify-content-md-end">
            <div class="btn-group btn-group-sm">
                <button class="btn @(_viewMode == ViewMode.Tree ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SetViewMode(ViewMode.Tree)">Tree</button>
                <button class="btn @(_viewMode == ViewMode.List ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SetViewMode(ViewMode.List)">List</button>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ExpandAllAsync">Expand all</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CollapseAll">Collapse all</button>
        </div>
    </div>
</div>

@if (_loading)
{
    <p><em>Loading content tree...</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_roots.Count == 0)
{
    <div class="alert alert-info">
        No content yet.
        <a href="content/new">Create your first page</a>.
    </div>
}
else if (_viewMode == ViewMode.Tree)
{
    <div class="content-explorer row g-3">
        <div class="col-lg-4">
            <div class="content-explorer-tree card">
                <div class="card-header py-2">
                    <strong>Site structure</strong>
                </div>
                <div class="card-body p-2">
                    <ContentTreeBranch Roots="@_roots"
                                       ChildrenByParent="@_childrenByParent"
                                       ExpandedIds="@_expandedIds"
                                       SelectedId="@_selectedId"
                                       Search="@_search"
                                       CanReorder="@CanReorder"
                                       ReorderBusy="@_reorderBusy"
                                       BusyId="@_busyId"
                                       DraggedId="@_draggedContentId"
                                       DragOverId="@_dragOverContentId"
                                       OnToggleExpand="@ToggleExpandCallback"
                                       OnSelectNode="@SelectNodeCallback"
                                       OnMoveUp="@MoveContentUpCallback"
                                       OnMoveDown="@MoveContentDownCallback"
                                       OnDragStart="@StartDragCallback"
                                       OnDragEnd="@ClearDragStateCallback"
                                       OnDropOnNode="@DropOnNodeCallback"
                                       OnDragOverNode="@SetDragOverCallback"
                                       OnDragLeaveNode="@ClearDragOverCallback" />
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="content-explorer-preview card">
                <div class="card-header py-2">
                    <strong>Preview</strong>
                </div>
                <div class="card-body content-explorer-preview-body p-3">
                    <ContentPreviewPanel Item="@SelectedItem"
                                         IsBusy="@(_busyId.HasValue)"
                                         OnPublish="@PublishAsync"
                                         OnUnpublish="@UnpublishAsync"
                                         OnDelete="@ConfirmDelete" />
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="table-responsive content-tree-table">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width: 35%">Name</th>
                    <th>Path</th>
                    <th>Template</th>
                    <th>Status</th>
                    <th>Updated</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in VisibleListItems)
                {
                    var hasChildren = _childrenByParent.ContainsKey(item.Id) && _childrenByParent[item.Id].Count > 0;
                    var isExpanded = _expandedIds.Contains(item.Id);
                    var parentName = GetParentName(item.ParentId);
                    var moveAvailability = GetMoveAvailability(item);

                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2" style="padding-left: @(item.Level * 1.25)rem">
                                @if (hasChildren)
                                {
                                    <button class="btn btn-sm btn-link p-0 me-2" title="@(isExpanded ? "Collapse" : "Expand")"
                                            @onclick="() => ToggleExpand(item.Id)">
                                        <span class="oi @(isExpanded ? "oi-chevron-bottom" : "oi-chevron-right")"></span>
                                    </button>
                                }
                                else
                                {
                                    <span class="tree-list-leaf me-2">└</span>
                                }
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@item.Name</div>
                                    <div class="text-muted small">
                                        @item.Slug
                                        @if (parentName is not null)
                                        {
                                            <span class="ms-1">· child of <em>@parentName</em></span>
                                        }
                                    </div>
                                </div>
                                @if (CanReorder)
                                {
                                    <TreeReorderControls
                                        CanMoveUp="moveAvailability.CanMoveUp"
                                        CanMoveDown="moveAvailability.CanMoveDown"
                                        Disabled="@(_reorderBusy || _busyId.HasValue)"
                                        OnMoveUp="@(() => MoveContentAsync(item, moveUp: true))"
                                        OnMoveDown="@(() => MoveContentAsync(item, moveUp: false))"
                                        OnDragStart="@(() => StartDrag(item.Id))"
                                        OnDragEnd="@ClearDragState" />
                                }
                            </div>
                        </td>
                        <td><code class="small">@item.FullPath</code></td>
                        <td>@item.TemplateKey</td>
                        <td><StatusBadge Status="item.Status" /></td>
                        <td class="text-muted small">@item.UpdatedAt.LocalDateTime.ToString("g")</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-primary" href="content/edit/@item.Id">Edit</a>
                                <a class="btn btn-outline-secondary" href="content/new?parentId=@item.Id">Child</a>
                                @if (item.Status == ContentStatus.Published)
                                {
                                    <button class="btn btn-outline-warning" disabled="@_busyId.HasValue"
                                            @onclick="() => UnpublishAsync(item.Id)">Unpublish</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-success" disabled="@_busyId.HasValue"
                                            @onclick="() => PublishAsync(item.Id)">Publish</button>
                                }
                                <button class="btn btn-outline-danger" disabled="@_busyId.HasValue"
                                        @onclick="() => ConfirmDelete(item)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_deleteCandidate is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete content</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    Delete <strong>@_deleteCandidate.Name</strong>?
                    @if (_deleteCandidate.ParentId is Guid parentId && _contentById.TryGetValue(parentId, out var parent))
                    {
                        <span> (child of <strong>@parent.Name</strong>)</span>
                    }
                    <div class="mt-2 text-muted small">Child nodes must be removed first.</div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteConfirmedAsync">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private enum ViewMode { Tree, List }

    private bool _loading = true;
    private string? _error;
    private string? _bannerMessage;
    private bool _bannerIsError;
    private string _search = string.Empty;
    private Guid? _busyId;
    private ContentDto? _deleteCandidate;
    private ViewMode _viewMode = ViewMode.Tree;
    private Guid? _selectedId;

    private IReadOnlyList<ContentDto> _roots = [];
    private Dictionary<Guid, List<ContentDto>> _childrenByParent = new();
    private Dictionary<Guid, ContentDto> _contentById = new();
    private readonly HashSet<Guid> _expandedIds = [];
    private Guid? _draggedContentId;
    private Guid? _dragOverContentId;
    private bool _reorderBusy;

    [SupplyParameterFromQuery]
    public string? Saved { get; set; }

    [SupplyParameterFromQuery]
    public string? Published { get; set; }

    private IEnumerable<ContentDto> VisibleListItems =>
        ContentTreeHelper.FlattenVisible(_roots, _childrenByParent, _expandedIds, _search);

    private ContentDto? SelectedItem =>
        _selectedId is Guid id && _contentById.TryGetValue(id, out var item) ? item : null;

    protected override async Task OnInitializedAsync()
    {
        if (Saved == "1")
        {
            _bannerMessage = "Content saved successfully.";
        }
        else if (Published == "1")
        {
            _bannerMessage = "Content saved and published.";
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _roots = await ContentService.GetRootsAsync();
            _childrenByParent = await ContentTreeHelper.LoadChildrenLookupAsync(
                _roots,
                parentId => ContentService.GetChildrenAsync(parentId));

            _contentById = ContentTreeHelper.FlattenAll(_roots, _childrenByParent)
                .ToDictionary(c => c.Id);

            foreach (var root in _roots)
            {
                _expandedIds.Add(root.Id);
            }

            EnsureSelection();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetViewMode(ViewMode mode) => _viewMode = mode;

    private void OnSearchChanged()
    {
        if (!string.IsNullOrWhiteSpace(_search))
        {
            foreach (var id in ContentTreeHelper.GetExpandedIdsForSearch(_roots, _childrenByParent, _search))
            {
                _expandedIds.Add(id);
            }
        }
    }

    private async Task ExpandAllAsync()
    {
        foreach (var id in ContentTreeHelper.GetExpandableIds(_childrenByParent))
        {
            _expandedIds.Add(id);
        }

        await InvokeAsync(StateHasChanged);
    }

    private void CollapseAll()
    {
        _expandedIds.Clear();
        foreach (var root in _roots)
        {
            _expandedIds.Add(root.Id);
        }
    }

    private void ToggleExpand(Guid id)
    {
        if (!_expandedIds.Remove(id))
        {
            _expandedIds.Add(id);
        }
    }

    private Task SelectNodeAsync(Guid id)
    {
        _selectedId = id;
        return Task.CompletedTask;
    }

    private EventCallback<Guid> ToggleExpandCallback =>
        EventCallback.Factory.Create<Guid>(this, ToggleExpand);

    private EventCallback<Guid> SelectNodeCallback =>
        EventCallback.Factory.Create<Guid>(this, SelectNodeAsync);

    private EventCallback<ContentDto> MoveContentUpCallback =>
        EventCallback.Factory.Create<ContentDto>(this, item => MoveContentAsync(item, moveUp: true));

    private EventCallback<ContentDto> MoveContentDownCallback =>
        EventCallback.Factory.Create<ContentDto>(this, item => MoveContentAsync(item, moveUp: false));

    private EventCallback<Guid> StartDragCallback =>
        EventCallback.Factory.Create<Guid>(this, StartDrag);

    private EventCallback ClearDragStateCallback =>
        EventCallback.Factory.Create(this, ClearDragState);

    private EventCallback<ContentDto> DropOnNodeCallback =>
        EventCallback.Factory.Create<ContentDto>(this, DropOnNodeAsync);

    private EventCallback<Guid> SetDragOverCallback =>
        EventCallback.Factory.Create<Guid>(this, SetDragOver);

    private EventCallback ClearDragOverCallback =>
        EventCallback.Factory.Create(this, ClearDragOver);

    private void EnsureSelection()
    {
        if (_selectedId is Guid selectedId && _contentById.ContainsKey(selectedId))
        {
            return;
        }

        _selectedId = _roots.OrderBy(r => r.SortOrder).ThenBy(r => r.Name).FirstOrDefault()?.Id;
    }

    private string? GetParentName(Guid? parentId) =>
        parentId is Guid id && _contentById.TryGetValue(id, out var parent) ? parent.Name : null;

    private async Task PublishAsync(Guid id)
    {
        await RunActionAsync(id, async () =>
        {
            await ContentService.PublishContentAsync(id);
            _bannerMessage = "Content published.";
            _bannerIsError = false;
        });
    }

    private async Task UnpublishAsync(Guid id)
    {
        await RunActionAsync(id, async () =>
        {
            await ContentService.UnpublishContentAsync(id);
            _bannerMessage = "Content unpublished.";
            _bannerIsError = false;
        });
    }

    private async Task RunActionAsync(Guid id, Func<Task> action)
    {
        _busyId = id;
        try
        {
            await action();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _bannerMessage = ex.Message;
            _bannerIsError = true;
        }
        finally
        {
            _busyId = null;
        }
    }

    private void ConfirmDelete(ContentDto item) => _deleteCandidate = item;

    private void CancelDelete() => _deleteCandidate = null;

    private async Task DeleteConfirmedAsync()
    {
        if (_deleteCandidate is null)
        {
            return;
        }

        var id = _deleteCandidate.Id;
        _deleteCandidate = null;

        if (_selectedId == id)
        {
            _selectedId = null;
        }

        await RunActionAsync(id, async () =>
        {
            await ContentService.DeleteContentAsync(id);
            _bannerMessage = "Content deleted.";
            _bannerIsError = false;
        });
    }

    private void ClearBanner()
    {
        _bannerMessage = null;
        _bannerIsError = false;
    }

    private bool CanReorder => string.IsNullOrWhiteSpace(_search);

    private IReadOnlyList<ContentDto> GetContentSiblings(ContentDto item) =>
        TreeReorderHelper.GetSiblings(
            item,
            _roots,
            _childrenByParent,
            c => c.ParentId,
            c => c.SortOrder,
            c => c.Name);

    private (bool CanMoveUp, bool CanMoveDown) GetMoveAvailability(ContentDto item)
    {
        var siblings = GetContentSiblings(item);
        return TreeReorderHelper.GetMoveAvailability(siblings, item.Id, c => c.Id);
    }

    private void StartDrag(Guid id) => _draggedContentId = id;

    private void SetDragOver(Guid id)
    {
        if (_draggedContentId.HasValue)
        {
            _dragOverContentId = id;
        }
    }

    private void ClearDragOver() => _dragOverContentId = null;

    private void ClearDragState()
    {
        _draggedContentId = null;
        _dragOverContentId = null;
    }

    private async Task MoveContentAsync(ContentDto item, bool moveUp)
    {
        var siblings = GetContentSiblings(item);
        var orderedIds = moveUp
            ? TreeReorderHelper.MoveUp(siblings, item.Id, c => c.Id)
            : TreeReorderHelper.MoveDown(siblings, item.Id, c => c.Id);

        if (orderedIds is null)
        {
            return;
        }

        await ReorderContentAsync(item.ParentId, orderedIds);
    }

    private async Task DropOnNodeAsync(ContentDto target)
    {
        if (_draggedContentId is not Guid draggedId || !_contentById.TryGetValue(draggedId, out var dragged))
        {
            ClearDragState();
            return;
        }

        if (dragged.ParentId != target.ParentId)
        {
            ClearDragState();
            return;
        }

        var siblings = GetContentSiblings(dragged);
        var orderedIds = TreeReorderHelper.ReorderAfterDrop(siblings, draggedId, target.Id, c => c.Id);
        ClearDragState();

        if (orderedIds is null)
        {
            return;
        }

        await ReorderContentAsync(dragged.ParentId, orderedIds);
    }

    private async Task ReorderContentAsync(Guid? parentId, IReadOnlyList<Guid> orderedIds)
    {
        _reorderBusy = true;
        try
        {
            await ContentService.ReorderSiblingsAsync(parentId, orderedIds);
            await ReloadAsync();
            _bannerMessage = "Content order updated.";
            _bannerIsError = false;
        }
        catch (Exception ex)
        {
            _bannerMessage = ex.Message;
            _bannerIsError = true;
        }
        finally
        {
            _reorderBusy = false;
        }
    }
}