@page "/orders"
@using Lumen.Application.Orders
@using Lumen.Application.Orders.Dtos
@using Lumen.Backoffice.Components.Orders
@using Lumen.Domain.Enums
@inject IOrderService OrderService

<PageTitle>Orders</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="mb-0">Orders</h1>
        <p class="text-muted mb-0">View and manage storefront orders.</p>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small text-muted mb-1">Search</label>
                <input class="form-control" placeholder="Order #, email, name..."
                       @bind="_search" @bind:event="oninput" @bind:after="ReloadAsync" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Order status</label>
                <select class="form-select" @bind="_statusFilter" @bind:after="ReloadAsync">
                    <option value="">All</option>
                    @foreach (var status in Enum.GetValues<OrderStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">Payment status</label>
                <select class="form-select" @bind="_paymentStatusFilter" @bind:after="ReloadAsync">
                    <option value="">All</option>
                    @foreach (var status in Enum.GetValues<PaymentStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">From date</label>
                <input type="date" class="form-control" @bind="_dateFrom" @bind:after="ReloadAsync" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">To date</label>
                <input type="date" class="form-control" @bind="_dateTo" @bind:after="ReloadAsync" />
            </div>
            <div class="col-md-1">
                <button class="btn btn-outline-secondary w-100" @onclick="ClearFiltersAsync">Clear</button>
            </div>
        </div>
        @if (_customerIdFilter is Guid customerId)
        {
            <div class="mt-2">
                <span class="badge bg-info text-dark">
                    Filtered by customer <code>@customerId</code>
                    <a class="text-dark ms-1" href="orders">×</a>
                </span>
            </div>
        }
    </div>
</div>

@if (_loading)
{
    <p><em>Loading orders...</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_orders.Count == 0)
{
    <div class="alert alert-info">No orders match the current filters.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="text-muted small">@_orders.Count order(s)</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Order</th>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Payment</th>
                    <th class="text-end">Total</th>
                    <th>Placed</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in _orders)
                {
                    <tr>
                        <td><code>@order.OrderNumber</code></td>
                        <td>@order.CustomerName</td>
                        <td class="small">@order.Email</td>
                        <td><OrderStatusBadge Status="@order.Status" /></td>
                        <td><PaymentStatusBadge Status="@order.PaymentStatus" /></td>
                        <td class="text-end fw-semibold">@order.Subtotal.ToString("C")</td>
                        <td class="text-muted small">@order.CreatedAt.LocalDateTime.ToString("g")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="orders/@order.Id">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "customerId")]
    public Guid? CustomerIdFilter { get; set; }

    private bool _loading = true;
    private string? _error;
    private string _search = string.Empty;
    private string _statusFilter = string.Empty;
    private string _paymentStatusFilter = string.Empty;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private Guid? _customerIdFilter;
    private IReadOnlyList<OrderDto> _orders = [];

    protected override async Task OnParametersSetAsync()
    {
        _customerIdFilter = CustomerIdFilter;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            OrderStatus? status = string.IsNullOrWhiteSpace(_statusFilter)
                ? null
                : Enum.Parse<OrderStatus>(_statusFilter);

            PaymentStatus? paymentStatus = string.IsNullOrWhiteSpace(_paymentStatusFilter)
                ? null
                : Enum.Parse<PaymentStatus>(_paymentStatusFilter);

            DateTimeOffset? from = _dateFrom is { } df
                ? new DateTimeOffset(df.Date, TimeSpan.Zero)
                : null;

            DateTimeOffset? to = _dateTo is { } dt
                ? new DateTimeOffset(dt.Date.AddDays(1).AddTicks(-1), TimeSpan.Zero)
                : null;

            _orders = await OrderService.ListAsync(new OrderListFilter(
                Status: status,
                PaymentStatus: paymentStatus,
                CustomerId: _customerIdFilter,
                Search: string.IsNullOrWhiteSpace(_search) ? null : _search,
                From: from,
                To: to));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ClearFiltersAsync()
    {
        _search = string.Empty;
        _statusFilter = string.Empty;
        _paymentStatusFilter = string.Empty;
        _dateFrom = null;
        _dateTo = null;
        _customerIdFilter = null;
        CustomerIdFilter = null;
        await ReloadAsync();
    }
}