@page "/orders/{Id:guid}"
@using Lumen.Application.Orders
@using Lumen.Application.Orders.Dtos
@using Lumen.Backoffice.Components.Orders
@using Lumen.Domain.Enums
@inject IOrderService OrderService

<PageTitle>Order</PageTitle>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="orders">Orders</a></li>
        <li class="breadcrumb-item active" aria-current="page">@(_order?.OrderNumber ?? "Details")</li>
    </ol>
</nav>

@if (_loading)
{
    <p><em>Loading order...</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_order is not null)
{
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
            <h1 class="mb-1"><code>@_order.OrderNumber</code></h1>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <OrderStatusBadge Status="@_order.Status" />
                <PaymentStatusBadge Status="@_order.PaymentStatus" />
                <span class="text-muted small">Placed @_order.CreatedAt.LocalDateTime.ToString("f")</span>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            @if (CanCancel)
            {
                <button class="btn btn-sm btn-outline-danger" disabled="@_actionInProgress" @onclick="CancelOrderAsync">
                    Cancel order
                </button>
            }
            <button class="btn btn-sm btn-outline-primary" disabled="@_actionInProgress" @onclick="SendNotificationAsync">
                Send notification
            </button>
        </div>
    </div>

    @if (_bannerMessage is not null)
    {
        <div class="alert @(_bannerIsError ? "alert-danger" : "alert-success")">@_bannerMessage</div>
    }

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header">Customer</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@_order.CustomerName</dd>
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@_order.Email</dd>
                        <dt class="col-sm-4">Customer ID</dt>
                        <dd class="col-sm-8">
                            @if (_order.CustomerId is Guid customerId)
                            {
                                <a href="customers/@customerId"><code class="small">@customerId</code></a>
                            }
                            else
                            {
                                <span class="text-muted">Guest checkout</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Payment</span>
                    @if (_order.PaymentProvider is not null)
                    {
                        <span class="badge bg-light text-dark">@_order.PaymentProvider</span>
                    }
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Status</dt>
                        <dd class="col-sm-7"><PaymentStatusBadge Status="@_order.PaymentStatus" /></dd>
                        <dt class="col-sm-5">Transaction ID</dt>
                        <dd class="col-sm-7">
                            @if (string.IsNullOrWhiteSpace(_order.PaymentTransactionId))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <code class="small">@_order.PaymentTransactionId</code>
                            }
                        </dd>
                        <dt class="col-sm-5">Captured</dt>
                        <dd class="col-sm-7">@_order.AmountCaptured.ToString("C")</dd>
                        <dt class="col-sm-5">Refunded</dt>
                        <dd class="col-sm-7">@_order.AmountRefunded.ToString("C")</dd>
                        @if (!string.IsNullOrWhiteSpace(_order.PaymentMessage))
                        {
                            <dt class="col-sm-5">Message</dt>
                            <dd class="col-sm-7 small text-muted">@_order.PaymentMessage</dd>
                        }
                    </dl>

                    @if (CanCapture || CanRefund)
                    {
                        <hr />
                        <div class="d-flex flex-wrap gap-2 align-items-end">
                            @if (CanCapture)
                            {
                                <button class="btn btn-sm btn-success" disabled="@_paymentActionInProgress" @onclick="CapturePaymentAsync">
                                    @(_paymentActionInProgress ? "Processing..." : "Capture payment")
                                </button>
                            }
                            @if (CanRefund)
                            {
                                <div>
                                    <label class="form-label small text-muted mb-1">Refund amount</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control" min="0.01" step="0.01" @bind="_refundAmount" disabled="@_paymentActionInProgress" />
                                        <button class="btn btn-outline-danger" disabled="@(_paymentActionInProgress || _refundAmount <= 0)" @onclick="RefundPaymentAsync">
                                            Refund
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header">Order notes</div>
                <div class="card-body">
                    @if (string.IsNullOrWhiteSpace(_order.OrderNotes))
                    {
                        <span class="text-muted">No notes provided.</span>
                    }
                    else
                    {
                        <p class="mb-0">@_order.OrderNotes</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">Shipping address</div>
                <div class="card-body">
                    <address class="mb-0">
                        <strong>@_order.ShippingAddress.Name</strong><br />
                        @_order.ShippingAddress.Line1<br />
                        @if (!string.IsNullOrWhiteSpace(_order.ShippingAddress.Line2))
                        {
                            @_order.ShippingAddress.Line2<br />
                        }
                        @_order.ShippingAddress.PostalCode @_order.ShippingAddress.City<br />
                        @if (!string.IsNullOrWhiteSpace(_order.ShippingAddress.Region))
                        {
                            @_order.ShippingAddress.Region<br />
                        }
                        @_order.ShippingAddress.Country
                    </address>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">Billing address</div>
                <div class="card-body">
                    <address class="mb-0">
                        <strong>@_order.BillingAddress.Name</strong><br />
                        @_order.BillingAddress.Line1<br />
                        @if (!string.IsNullOrWhiteSpace(_order.BillingAddress.Line2))
                        {
                            @_order.BillingAddress.Line2<br />
                        }
                        @_order.BillingAddress.PostalCode @_order.BillingAddress.City<br />
                        @if (!string.IsNullOrWhiteSpace(_order.BillingAddress.Region))
                        {
                            @_order.BillingAddress.Region<br />
                        }
                        @_order.BillingAddress.Country
                    </address>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Line items</span>
            <span class="fw-semibold">@_order.Subtotal.ToString("C")</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Unit price</th>
                        <th class="text-end">Line total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _order.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td><code class="small">@item.Sku</code></td>
                            <td class="text-end">@item.Quantity</td>
                            <td class="text-end">@item.UnitPrice.ToString("C")</td>
                            <td class="text-end fw-semibold">@item.LineTotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-header">Update status</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small text-muted">New status</label>
                        <select class="form-select form-select-sm" @bind="_selectedStatus" disabled="@_saving">
                            @foreach (var status in Enum.GetValues<OrderStatus>())
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Note (optional)</label>
                        <textarea class="form-control form-control-sm" rows="3" @bind="_statusNote" disabled="@_saving"
                                  placeholder="Reason or internal note for this status change..."></textarea>
                    </div>
                    <button class="btn btn-sm btn-primary" disabled="@(_saving || (_selectedStatus == _order.Status && string.IsNullOrWhiteSpace(_statusNote)))" @onclick="SaveStatusAsync">
                        @(_saving ? "Saving..." : "Save status")
                    </button>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header">Order timeline</div>
                <div class="card-body">
                    <OrderTimeline Entries="@_history" />
                </div>
            </div>
        </div>
    </div>

    <a class="btn btn-outline-secondary mt-3" href="orders">Back to orders</a>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _loading = true;
    private bool _saving;
    private bool _paymentActionInProgress;
    private bool _actionInProgress;
    private string? _error;
    private string? _bannerMessage;
    private bool _bannerIsError;
    private OrderDto? _order;
    private OrderStatus _selectedStatus;
    private string _statusNote = string.Empty;
    private decimal _refundAmount;
    private IReadOnlyList<OrderHistoryEntryDto> _history = [];

    private bool CanCapture =>
        _order is not null &&
        !string.IsNullOrWhiteSpace(_order.PaymentTransactionId) &&
        _order.PaymentStatus is PaymentStatus.Authorized or PaymentStatus.Pending;

    private bool CanRefund =>
        _order is not null &&
        !string.IsNullOrWhiteSpace(_order.PaymentTransactionId) &&
        _order.PaymentStatus is PaymentStatus.Authorized or PaymentStatus.Captured or PaymentStatus.PartiallyRefunded &&
        _order.AmountRefunded < _order.Subtotal;

    private bool CanCancel =>
        _order is not null &&
        _order.Status is not OrderStatus.Cancelled and not OrderStatus.Shipped and not OrderStatus.Completed;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        _bannerMessage = null;

        try
        {
            _order = await OrderService.GetByIdAsync(Id);
            if (_order is null)
            {
                _error = "Order not found.";
            }
            else
            {
                _selectedStatus = _order.Status;
                _refundAmount = Math.Max(0, _order.Subtotal - _order.AmountRefunded);
                _history = await OrderService.GetOrderHistoryAsync(Id);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CapturePaymentAsync()
    {
        if (_order is null)
        {
            return;
        }

        _paymentActionInProgress = true;
        _bannerMessage = null;

        try
        {
            _order = await OrderService.CapturePaymentAsync(_order.Id);
            _history = await OrderService.GetOrderHistoryAsync(_order.Id);
            _bannerMessage = "Payment captured.";
            _bannerIsError = false;
        }
        catch (Exception ex)
        {
            _bannerMessage = ex.Message;
            _bannerIsError = true;
        }
        finally
        {
            _paymentActionInProgress = false;
        }
    }

    private async Task RefundPaymentAsync()
    {
        if (_order is null)
        {
            return;
        }

        _paymentActionInProgress = true;
        _bannerMessage = null;

        try
        {
            _order = await OrderService.RefundPaymentAsync(_order.Id, _refundAmount);
            _refundAmount = Math.Max(0, _order.Subtotal - _order.AmountRefunded);
            _history = await OrderService.GetOrderHistoryAsync(_order.Id);
            _bannerMessage = "Refund processed.";
            _bannerIsError = false;
        }
        catch (Exception ex)
        {
            _bannerMessage = ex.Message;
            _bannerIsError = true;
        }
        finally
        {
            _paymentActionInProgress = false;
        }
    }

    private async Task SaveStatusAsync()
    {
        if (_order is null)
        {
            return;
        }

        _saving = true;
        _bannerMessage = null;

        try
        {
            _order = await OrderService.UpdateStatusWithNoteAsync(
                _order.Id,
                new UpdateOrderStatusRequest(_selectedStatus, _statusNote, "backoffice"));
            _statusNote = string.Empty;
            _history = await OrderService.GetOrderHistoryAsync(_order.Id);
            _bannerMessage = "Order status updated.";
            _bannerIsError = false;
        }
        catch (Exception ex)
        {
            _bannerMessage = ex.Message;
            _bannerIsError = true;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CancelOrderAsync()
    {
        if (_order is null)
        {
            return;
        }

        _actionInProgress = true;
        _bannerMessage = null;

        try
        {
            _order = await OrderService.CancelOrderAsync(_order.Id, actor: "backoffice");
            _selectedStatus = _order.Status;
            _history = await OrderService.GetOrderHistoryAsync(_order.Id);
            _bannerMessage = "Order cancelled.";
            _bannerIsError = false;
        }
        catch (Exception ex)
        {
            _bannerMessage = ex.Message;
            _bannerIsError = true;
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private async Task SendNotificationAsync()
    {
        if (_order is null)
        {
            return;
        }

        _actionInProgress = true;
        _bannerMessage = null;

        try
        {
            _order = await OrderService.SendOrderNotificationAsync(_order.Id, actor: "backoffice");
            _history = await OrderService.GetOrderHistoryAsync(_order.Id);
            _bannerMessage = "Notification queued (stub).";
            _bannerIsError = false;
        }
        catch (Exception ex)
        {
            _bannerMessage = ex.Message;
            _bannerIsError = true;
        }
        finally
        {
            _actionInProgress = false;
        }
    }
}