@model Lumen.Storefront.Controllers.AccountController.LoginViewModel
@{
    ViewData["Title"] = "Log in";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<h1 class="mb-3">Log in</h1>

<form method="post" action="/account/login">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label class="form-label" asp-for="Email"></label>
        <input class="form-control" asp-for="Email" />
    </div>
    <div class="mb-3">
        <label class="form-label" asp-for="Password"></label>
        <input class="form-control" asp-for="Password" />
    </div>
    <div class="form-check mb-3">
        <input class="form-check-input" asp-for="RememberMe" />
        <label class="form-check-label" asp-for="RememberMe"></label>
    </div>

    <button type="submit" class="btn btn-primary">Log in</button>
    <a class="btn btn-link" href="/account/register">Create an account</a>
</form>