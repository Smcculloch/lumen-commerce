@model Lumen.Storefront.Models.CartPageViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<h1 class="mb-3">Shopping Cart</h1>

@if (TempData["CartMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["CartError"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">
        Your cart is empty. <a href="/shop">Browse products</a>.
    </div>
}
else
{
    <div class="table-responsive mb-4">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>SKU</th>
                    <th class="text-end">Price</th>
                    <th style="width: 8rem">Qty</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td><code class="small">@item.Sku</code></td>
                        <td class="text-end">@item.UnitPrice.ToString("C")</td>
                        <td>
                            <form method="post" action="/cart/update" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lineItemId" value="@item.Id" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control form-control-sm" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                            </form>
                        </td>
                        <td class="text-end fw-semibold">@item.LineTotal.ToString("C")</td>
                        <td class="text-end">
                            <form method="post" action="/cart/remove">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lineItemId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <form method="post" action="/cart/clear" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary">Clear cart</button>
            </form>
            <a class="btn btn-link" href="/shop">Continue shopping</a>
        </div>
        <div class="text-end">
            <div class="text-muted small">@Model.ItemCount item(s)</div>
            <div class="fs-4 fw-semibold">Subtotal: @Model.Subtotal.ToString("C")</div>
            <a class="btn btn-primary mt-2" href="/checkout">Proceed to checkout</a>
        </div>
    </div>
}