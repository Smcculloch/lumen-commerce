@model IReadOnlyList<Lumen.Storefront.Models.ProductDetailViewModel>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No published products yet.</div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 product-card">
                    <div class="card-body d-flex flex-column">
                        <p class="text-muted small mb-1"><code>@product.Sku</code></p>
                        <h2 class="h5 card-title">@product.Name</h2>
                        @if (!string.IsNullOrWhiteSpace(product.ShortDescription))
                        {
                            <p class="card-text text-muted">@product.ShortDescription</p>
                        }
                        @if (product.Price is decimal price)
                        {
                            <p class="fw-semibold mt-auto mb-3">@price.ToString("C")</p>
                        }
                        <a class="btn btn-outline-primary" href="/products/@product.Sku">View details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}